# =============================================
# VARIABLES DE ENTORNO - Cafetería Aroma API
# Copiar este archivo como .env y completar
# NUNCA subir .env a GitHub
# =============================================

# Puerto del servidor
PORT=3000

# URL del proyecto Supabase
SUPABASE_URL=https://XXXXXXXXXXXXXX.supabase.co

# Clave de servicio (privada, SOLO en backend)
# La encuentras en: Supabase > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL del frontend (para CORS)
# En producción: https://tu-cafeteria.netlify.app
# En desarrollo: http://localhost:5500
FRONTEND_URL=http://localhost:5500
